{
  "name": "audit-tool",
  "version": "2.0.0",
  "description": "Read-only GoHighLevel browser audit tool with slow cursor, workflow walking, admin-shutoff detection, and auto PDF reporting",
  "main": "audit.js",
  "scripts": {
    "audit": "node audit.js",
    "audit:store": "AUDIT_PROFILE=store AUDIT_TIERED=1 node audit.js",
    "capture": "node capture-ghl-readonly.js",
    "section-walk": "node section-walk-ghl-readonly.js",
    "deep-crawl": "node deep-ghl-readonly-crawl.js",
    "targeted": "node targeted-ghl-tabs-readonly.js",
    "retry-missed": "node retry-missed-pages-30s.js",
    "funnel-tabs": "node funnel-tabs-readonly.js",
    "check": "find . -path ./node_modules -prune -o -name '*.js' -print0 | xargs -0 -n1 node --check",
    "test": "npm run check && node --test"
  },
  "keywords": ["audit", "gohighlevel", "browser-automation", "read-only", "playwright"],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "playwright-core": "^1.61.1"
  }
}
